{
  "name": "server",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/server/src",
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "options": {
        "main": "apps/server/src/local.ts",
        "additionalEntryPoints": ["apps/server/src/lambda.ts"],
        "tsConfig": "apps/server/tsconfig.json",
        "outputPath": "apps/server/dist",
        "platform": "node",
        "format": ["esm"],
        "bundle": true,
        "sourcemap": true
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx src/local.ts",
        "cwd": "apps/server"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node dist/local.js",
        "cwd": "apps/server"
      }
    },
    "lambda": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node dist/lambda.js",
        "cwd": "apps/server"
      }
    },
    "eslint:lint": {
      "executor": "@nx/eslint:lint"
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tsconfig.json --noEmit",
        "cwd": "apps/server"
      }
    }
  },
  "tags": []
}
